		</personaText>
		<voiceId>cassandra_voice</voiceId>
		<voiceProviders>
			<li>
				<name>google</name>
				<voice>Zephyr</voice>
			</li>
			<li>
				<name>open_ai</name>
				<voice>nova</voice>
			</li>
		</voiceProviders>
	</LivingStoryteller.StorytellerPersonaDef>

